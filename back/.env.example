# ==================================
# Proxicare API - Configuration
# ==================================
# Copier ce fichier en .env et adapter les valeurs

# ==================================
# Application
# ==================================
NODE_ENV=development
PORT=3000
API_PORT=3000

# ==================================
# Base de données PostgreSQL
# ==================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=proxicare
DB_USER=proxicare
DB_PASSWORD=proxicare_password

# ==================================
# Auth0 (Authentification)
# ==================================
AUTH0_DOMAIN=dev-nsvd7ah63vgjbmoy.eu.auth0.com
AUTH0_AUDIENCE=https://localhost:5000/

# ==================================
# CORS
# ==================================
# Liste des origines autorisées (séparées par des virgules)
API_CORS=http://localhost:4200,http://localhost:3000

# ==================================
# pgAdmin (optionnel - dev)
# ==================================
PGADMIN_PORT=5050
PGADMIN_EMAIL=admin@proxicare.com
PGADMIN_PASSWORD=admin
